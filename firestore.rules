rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['id', 'email', 'lastActive'])
        && request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.lastActive is number;
    }

    // 2. Chats collection
    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && isValidId(chatId);
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'updatedAt']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // 3. Messages subcollection
      match /messages/{messageId} {
        allow list, get: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid);
        allow create: if isSignedIn() 
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid)
          && request.resource.data.role in ['user', 'assistant', 'model']
          && request.resource.data.content is string
          && request.resource.data.content.size() <= 10000;
        allow update: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']);
      }
    }
  }
}
